# ─────────────────────────────────────────────────────────────────────────────
# tutor-market (Next.js — app phụ huynh). Copy sang `.env` để chạy local.
# DEV: chạy được với default. PROD: xem chú thích "PROD" từng biến.
#
# Hai đường gọi API:
#  - SSR/public (server-side fetch): dùng API_BASE_URL (URL tuyệt đối).
#  - Client shell riêng tư (browser): gọi "/api/*" cùng-origin → Next rewrite
#    forward sang API_PROXY_TARGET (mirror dev proxy của tutor-app/admin).
# ─────────────────────────────────────────────────────────────────────────────

# URL server-only để SSR gọi tutor-api. KHÔNG có default production — PROD BẮT
# BUỘC set URL nội bộ tới API, vd https://api.kimthanh.vn/api/v1 (hoặc service nội bộ).
API_BASE_URL=http://localhost:3000/api/v1

# Target Next rewrite cho "/api/*" phía browser (chỉ dev/self-host). PROD: nếu
# đã reverse proxy same-origin thì rewrite trỏ tới API nội bộ; đọc từ shell env.
API_PROXY_TARGET=http://127.0.0.1:3000

# Host canonical public (SEO/canonical/OG), KHÔNG kèm "/" cuối.
# PROD: domain thật, vd https://kimthanh.vn
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Chỉ để review UI local khi tutor-api chưa chạy; PRODUCTION luôn bỏ qua.
MARKET_DEV_FIXTURES=false
