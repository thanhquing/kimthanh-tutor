# ─────────────────────────────────────────────────────────────────────────────
# tutor-api env. Copy sang `.env` (gitignored, KHÔNG bake vào image). Docker
# nạp file này qua `env_file` trong docker-compose.yml.
#
# CHECKLIST PROD (BẮT BUỘC đổi khỏi giá trị dev):
#   NODE_ENV=production
#   JWT_ACCESS_SECRET / JWT_REFRESH_SECRET   → secret mạnh ≥16 ký tự, KHÁC nhau
#   MEDIA_SIGNING_SECRET, SEPAY_WEBHOOK_API_KEY → secret mạnh
#   CORS_ORIGINS                              → origin FE prod (app/market/admin)
#   DATABASE_URL                              → Postgres prod
#   RESEND_API_KEY + MAIL_FROM                → gửi email thật (không có → chặn ở prod)
#   GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET   → (bắt buộc cho OAuth) từ Google Console
#   GOOGLE_OAUTH_REDIRECT_URI                 → URL callback PROD, TRÙNG Google Console
#   OAUTH_RETURN_URLS                         → origin FE prod được redirect về
#   APP_BASE_URL                              → base link trong email prod
#   FACEBOOK_APP_ID/SECRET                    → nếu bật Facebook
# Validation prod cứng ở src/config/env.validation.ts (fail-closed khi thiếu).
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# Database (PostgreSQL 15+)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutor?schema=public"

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Mật khẩu (email + password là phương thức đăng nhập hiện tại)
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# Email giao dịch (Resend) — verify email + reset password
# Non-prod thiếu RESEND_API_KEY → API trả dev_verification_link/dev_reset_link để test
RESEND_API_KEY=
MAIL_FROM=Kim Thành Tutor <no-reply@kimthanh.tutor>
APP_BASE_URL=http://localhost:5173
MAIL_VERIFY_TTL_SECONDS=86400
MAIL_RESET_TTL_SECONDS=3600

# Social login — Google dùng Authorization Code flow server-side (bảo mật).
# Lấy Client ID + Secret ở Google Cloud Console (OAuth Web application).
# Redirect URI phải trùng chính xác giá trị đăng ký ở Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile
# TTL cookie state chống CSRF giữa /start và /callback (giây).
OAUTH_STATE_TTL_SECONDS=600
# Allowlist origin FE được redirect về sau callback (chống open-redirect).
OAUTH_RETURN_URLS=http://localhost:5174,http://localhost:3001
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Chính sách xác thực — whitelist domain email đăng ký + khóa tài khoản.
# AUTH_ALLOWED_EMAIL_DOMAINS: danh sách domain exact được phép (cách nhau dấu phẩy).
# AUTH_ALLOW_EDU_EMAILS: bật rule chấp nhận domain trường học chứa nhãn `edu`.
AUTH_ALLOWED_EMAIL_DOMAINS=gmail.com
AUTH_ALLOW_EDU_EMAILS=true
AUTH_ADMIN_LOCK_THRESHOLD=5
AUTH_ADMIN_LOCK_DURATION_SECONDS=900
AUTH_USER_LOCK_THRESHOLD=10
AUTH_USER_LOCK_DURATION_SECONDS=900
# Grace chống race rotate refresh khi nhiều tab dùng chung cookie (ms).
AUTH_REFRESH_CONCURRENCY_GRACE_MS=5000

# Rate limit — global + nhóm auth nhạy cảm (window tính bằng giây).
GLOBAL_THROTTLE_WINDOW_SECONDS=60
GLOBAL_THROTTLE_LIMIT=120
AUTH_THROTTLE_WINDOW_SECONDS=300
AUTH_THROTTLE_LIMIT_STRICT=5
AUTH_THROTTLE_LIMIT_MEDIUM=10
AUTH_THROTTLE_LIMIT_RELAXED=30

# Redis (cache / rate limit / lock / queue) — bật khi dùng
REDIS_URL=redis://localhost:6379

# Consent — có thu IP/User-Agent không (theo 14-data-privacy)
CONSENT_STORE_IP=true
CONSENT_STORE_USER_AGENT=true

# Payment: VietQR + webhook biến động số dư (SePay/Casso)
PLATFORM_BANK_CODE=
PLATFORM_BANK_ACCOUNT=
PLATFORM_BANK_ACCOUNT_NAME=
SEPAY_WEBHOOK_API_KEY=change-me
SEPAY_IP_ALLOWLIST=

# Object storage (media) — S3 compatible
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
