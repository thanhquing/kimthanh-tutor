# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# Database (PostgreSQL 15+)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutor?schema=public"

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Social login
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Redis (cache / rate limit / lock / queue) — bật khi dùng
REDIS_URL=redis://localhost:6379

# Consent — có thu IP/User-Agent không (theo 14-data-privacy)
CONSENT_STORE_IP=true
CONSENT_STORE_USER_AGENT=true

# Payment: VietQR + webhook biến động số dư (SePay/Casso)
PLATFORM_BANK_CODE=
PLATFORM_BANK_ACCOUNT=
PLATFORM_BANK_ACCOUNT_NAME=
SEPAY_WEBHOOK_API_KEY=change-me
SEPAY_IP_ALLOWLIST=

# Object storage (media) — S3 compatible
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
