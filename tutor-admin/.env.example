# ─────────────────────────────────────────────────────────────────────────────
# tutor-admin (Vite SPA — console quản trị nội bộ). Copy sang `.env` chạy local.
# DEV: chạy được với default. PROD: xem chú thích "PROD" từng biến.
# ─────────────────────────────────────────────────────────────────────────────

# Base API phía client. Cùng-origin (khuyến nghị): "/api/v1" + reverse proxy
# route "/api" → tutor-api. Chỉ cấu hình tại build/deploy; UI prod không cho đổi.
# PROD: giữ "/api/v1" (same-origin proxy) hoặc URL tuyệt đối nếu API khác origin.
VITE_API_BASE_URL=/api/v1

# Target proxy dev cho "/api" — CHỈ tác dụng khi `vite dev` (shell env, không
# phải biến VITE_ client). PROD: bỏ qua (reverse proxy thật thay thế).
API_PROXY_TARGET=http://127.0.0.1:3000

# Nhãn môi trường build (hiển thị/telemetry). PROD: production.
VITE_BUILD_ENV=development

# Auto-logout khi idle (ms). Mặc định 15 phút. PROD: chỉnh theo chính sách bảo mật.
VITE_SESSION_IDLE_TIMEOUT_MS=900000
