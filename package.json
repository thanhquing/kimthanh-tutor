{
  "name": "kimthanh-tutor",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo cho he thong Kim Thanh Tutor giai doan 1.",
  "engines": {
    "node": ">=18.12",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "dev:api": "pnpm --filter tutor-api start:dev",
    "dev:market": "pnpm --filter tutor-market dev",
    "dev:app": "pnpm --filter tutor-app dev",
    "dev:admin": "pnpm --filter tutor-admin dev"
  }
}
