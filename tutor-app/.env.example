# ─────────────────────────────────────────────────────────────────────────────
# tutor-app (Vite SPA — app gia sư). Copy sang `.env` để chạy local (gitignored).
# DEV: chạy được với TOÀN BỘ default, không cần set gì (gọi API qua proxy /api).
# PROD: xem chú thích "PROD" từng biến.
# ─────────────────────────────────────────────────────────────────────────────

# Base API phía client. Cùng-origin (khuyến nghị): để "/api/v1" và cho reverse
# proxy/CDN route "/api" → tutor-api. PROD: giữ "/api/v1" nếu có reverse proxy
# same-origin; nếu API khác origin thì đặt URL tuyệt đối (vd https://app.kimthanh.vn/api/v1).
VITE_API_BASE_URL=/api/v1

# Target proxy dev cho "/api" — CHỈ tác dụng khi `vite dev` (đọc từ shell env,
# KHÔNG phải biến VITE_ client). PROD: bỏ qua (reverse proxy thật thay thế).
API_PROXY_TARGET=http://127.0.0.1:3000

# Panel chẩn đoán dev (chỉ hiệu lực chế độ dev). PROD: false.
VITE_ENABLE_DEV_DIAGNOSTICS=false

# Google login chạy SERVER-SIDE (nút chỉ là link tới /auth/oauth/google/start) →
# FE KHÔNG cần client id nữa; để trống. Cấu hình Google nằm ở tutor-api/.env.
# (Biến này chỉ còn cho luồng GIS client-side cũ, hiện không dùng.)
VITE_GOOGLE_CLIENT_ID=

# Facebook (luồng client-side, bật khi có app id). PROD: điền nếu dùng Facebook.
VITE_FACEBOOK_APP_ID=
VITE_FACEBOOK_API_VERSION=v21.0

# Link "Về Chợ gia sư" = origin tutor-market. PROD: domain market thật
# (vd https://kimthanh.vn hoặc https://market.kimthanh.vn).
VITE_MARKET_URL=http://localhost:3001
